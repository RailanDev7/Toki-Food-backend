generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int          @id @default(autoincrement())
  name       String
  email      String       @unique
  password   String
  createdAt  DateTime     @default(now())
  address    Address[]
  email_code Email_code[]
  profile    Profile[]
  usercpf    UserCPF?
}

model UserCPF {
  id         Int      @id @default(autoincrement())
  cpf        String   @unique
  data_nasci String
  user_id    Int      @unique
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])
}

model Profile {
  id        Int      @id @default(autoincrement())
  photo     String?
  user_id   Int
  bio       String?
  genero    Gender?  @default(sem_preferencia)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [user_id], references: [id])

  @@index([user_id], map: "Profile_user_id_fkey")
}

model Address {
  id          Int      @id @default(autoincrement())
  cep         String
  rua         String
  numero      String?
  bairro      String
  cidade      String
  estado      String
  complemento String?
  latitude    Float
  longitude   Float
  user_id     Int
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id])

  @@index([user_id], map: "Address_user_id_fkey")
}

model Email_code {
  id           Int          @id @default(autoincrement())
  verification Verification @default(nao_verificado)
  user_id      Int
  code         String
  expiresAt    DateTime
  createdAt    DateTime     @default(now())
  user         User         @relation(fields: [user_id], references: [id])

  @@index([user_id], map: "Email_code_user_id_fkey")
}

enum Gender {
  sem_preferencia
  femenino
  masculino
}

enum Verification {
  verificado
  nao_verificado
}
